@page "/cash"

<h3>Zakat Calculation for Cash</h3>

<div class="row">
    <div class="col-md-6">

        <div class="form-group">
            <label>Total Cash (US Dollar)</label>
            <input type="number" class="form-control" @bind="CashAmount" />
        </div>

        <br />

        <button class="btn btn-primary" @onclick="Calculate">Calculate</button>

    </div>

    <div class="col-md-6">

        <h4>Results</h4>

        <p><b>Total Zakatable Amount:</b> @ZakatableAmount.ToString("C")</p>
        <p><b>Total Zakat (2.5%):</b> @TotalZakat.ToString("C")</p>

    </div>
</div>

@code {

    double CashAmount;

    double ZakatableAmount;
    double TotalZakat;

    void Calculate()
    {
        ZakatableAmount = CashAmount;

        if (ZakatableAmount < 0)
            ZakatableAmount = 0;

        TotalZakat = ZakatableAmount * 0.025;
    }
}

