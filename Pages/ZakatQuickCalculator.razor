@page "/zakatcalculator"

<h3>Zakat Calculator</h3>

<div class="row">
    <div class="col-md-6">

        <div class="form-group">
            <label>Is your age 59 and half or more?</label>
            <InputSelect class="form-control" @bind-Value="Over59">
                <option value="true">Yes</option>
                <option value="false">No</option>
            </InputSelect>
        </div>

        <div class="form-group">
            <label>Regular 401K Balance</label>
            <input type="number" class="form-control" @bind="Regular401K" />
        </div>

        <div class="form-group">
            <label>IRA Balance</label>
            <input type="number" class="form-control" @bind="IRA" />
        </div>

        <div class="form-group">
            <label>Roth 401K Total Balance</label>
            <input type="number" class="form-control" @bind="Roth401K" />
        </div>

        <div class="form-group">
            <label>Roth 401K Profit</label>
            <input type="number" class="form-control" @bind="Roth401KProfit" />
        </div>

        <div class="form-group">
            <label>Have you held the Roth 401K account for at least five years?</label>
            <InputSelect class="form-control" @bind-Value="AccountAgeRoth401K">
                <option value="true">Yes</option>
                <option value="false">No</option>
            </InputSelect>
        </div>

        <div class="form-group">
            <label>Roth IRA Total Balance</label>
            <input type="number" class="form-control" @bind="RothIRA" />
        </div>

        <div class="form-group">
            <label>Roth IRA Profit</label>
            <input type="number" class="form-control" @bind="RothIRAProfit" />
        </div>

        <div class="form-group">
            <label>Have you held the Roth IRA account for at least five years?</label>
            <InputSelect class="form-control" @bind-Value="AccountAgeRothIRA">
                <option value="true">Yes</option>
                <option value="false">No</option>
            </InputSelect>
        </div>

        <div class="form-group">
            <label>Brokerage Account Balance</label>
            <input type="number" class="form-control" @bind="Brokerage" />
        </div>

        <div class="form-group">
            <label>Brokerage Account Profit</label>
            <input type="number" class="form-control" @bind="BrokerageProfit" />
        </div>

        <div class="form-group">
            <label>Gold</label>
            <input type="number" class="form-control" @bind="Gold" />
        </div>

        <div class="form-group">
            <label>Cash</label>
            <input type="number" class="form-control" @bind="Cash" />
        </div>

        <div class="form-group">
            <label>Total Yearly Loan Payment</label>
            <input type="number" class="form-control" @bind="LoanPayment" />
        </div>

        <div class="form-group">
            <label>Federal Tax Rate (%)</label>
            <input type="number" class="form-control" @bind="FedTaxRate" />
        </div>

        <div class="form-group">
            <label>State Tax Rate (%)</label>
            <input type="number" class="form-control" @bind="StateTaxRate" />
        </div>

        <br />

        <button class="btn btn-primary" @onclick="Calculate">Calculate</button>

    </div>

    <div class="col-md-6">

        <h4>Results</h4>

        <p><b>Total Balance:</b> @TotalBalance.ToString("C")</p>
        <p><b>Total Penalty:</b> @Penalty.ToString("C")</p>
        <p><b>Total Balance After 10% Penalty:</b> @PenaltyBalance.ToString("C")</p>
        <p><b>Total Tax:</b> @Tax.ToString("C")</p>
        <p><b>Total Balance After Tax:</b> @AfterTaxBalance.ToString("C")</p>
        <p><b>Total Zakatable Amount:</b> @ZakatableAmount.ToString("C")</p>
        <p><b>Total Zakat (2.5%):</b> @TotalZakat.ToString("C")</p>
        @if (showResult)
        {
        <button @onclick="ResetInputs">Reset</button>
        }
    </div>
</div>



@code {

    bool showResult = false;
    bool Over59;
    double Regular401K;
    double IRA;
    double Roth401K;
    double Roth401KProfit;
    bool AccountAgeRoth401K;
    double RothIRA;
    double RothIRAProfit;
    bool AccountAgeRothIRA;
    double Brokerage;
    double BrokerageProfit;
    double Gold;
    double Cash;
    double LoanPayment;
    double FedTaxRate;
    double StateTaxRate;

    double TotalBalance = 0;
    double Penalty = 0;
    double Tax = 0;
    double PenaltyBalance = 0;
    double AfterTaxBalance = 0;
    double ZakatableAmount = 0;
    double TotalZakat = 0;

    void Calculate()
    {
         double totalBalance = Regular401K + IRA + Roth401K + RothIRA + Brokerage + Gold + Cash;

         double taxRateDecimal = (FedTaxRate + StateTaxRate) / 100.0;
         double penaltyRateDecimal = 0.10;

         double tax = (Regular401K + IRA) * taxRateDecimal;
         double penalty = 0;

         if (!Over59)
         {
             penalty = (Regular401K + IRA) * penaltyRateDecimal;
         }

         if ((!Over59 || !AccountAgeRoth401K) && Roth401KProfit > 0)
         {
             penalty += Roth401KProfit * penaltyRateDecimal;
             tax += Roth401KProfit * taxRateDecimal;
         }

         if ((!Over59 || !AccountAgeRothIRA) && RothIRAProfit > 0)
         {
             penalty += RothIRAProfit * penaltyRateDecimal;
             tax += RothIRAProfit * taxRateDecimal;
         }

         if (BrokerageProfit > 0)
         {
             tax += BrokerageProfit * taxRateDecimal;
         }

         double penaltyBalance = totalBalance - penalty;
         double afterTaxBalance = penaltyBalance - tax;
         double zakatableAmount = Math.Max(0, afterTaxBalance - LoanPayment);

         if (zakatableAmount < 0)
         zakatableAmount = 0;

         double totalZakat = zakatableAmount * 0.025;

         // Assign once at the end (UI updates cleanly)
         TotalBalance = totalBalance;
         Penalty = penalty;
         Tax = tax;
         PenaltyBalance = penaltyBalance;
         AfterTaxBalance = afterTaxBalance;
         ZakatableAmount = zakatableAmount;
         TotalZakat = totalZakat;

         showResult = true;
    }

    void ResetInputs()
    {
        Regular401K = 0;
        IRA = 0;
        Roth401K = 0;
        Roth401KProfit = 0;
        RothIRA = 0;
        RothIRAProfit = 0;
        Brokerage = 0;
        BrokerageProfit = 0;
        Gold = 0;
        Cash = 0;
        LoanPayment = 0;
    }
}
